# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# .env (ROOT) вЂ” BACKEND config + values interpolated by the docker-compose files.
#
#   cp .env.example .env
#
# Used both in:
#   вЂў Hybrid dev (npm run start:dev): the backend reads this file (../.env).
#     The values below are the defaults for the local machine (host = localhost).
#   вЂў Docker (docker compose up): consumed as `env_file: .env` + `${VAR}`
#     interpolation in the compose files. The container-specific values (service
#     hosts, /app/... paths) are OVERRIDDEN by the `environment:` block of
#     docker-compose.yml вЂ” so there is NO need to change them here when moving
#     from dev to Docker.
#
# в”Ђв”Ђ ENV CONVENTION (all at the ROOT, one file per process, distinct names) в”Ђв”Ђв”Ђв”Ђв”Ђ
#   .env            в†’ backend (this file): ALL secrets, including the
#                     backend-ONLY ones (RUN_TOKEN_SECRET, TOOL_SECRETS_KEY, DB_*).
#   .env.executor   в†’ local executor (see .env.executor.example). Does NOT read
#                     this file: no backend secrets in the executor.
#   frontend/.env   в†’ frontend (VITE_*, Vite convention; stays in frontend/ because
#                     it goes into the bundle served to the browser в†’ NEVER backend
#                     secrets here).
#   embedding / whisper в†’ no .env: configured from docker-compose
#                     (build-args + environment, interpolated from EMBEDDING_*/WHISPER_*).
#
#   SERVICE_API_KEY is the ONLY shared value: it must be replicated IDENTICALLY in
#   .env and .env.executor (backendв†”executor auth mesh, fail-closed).
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# в”Ђв”Ђ REQUIRED (without these, the stack won't start вЂ” fail-closed) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# AES-256-GCM encryption of secrets (tool, datasource, LLM/vector API keys).
# 64 hex characters. Generate with: openssl rand -hex 32
TOOL_SECRETS_KEY=

# Signing secret for the internal run/daemon tokens (HMAC) used by the backend's
# /internal/* endpoints. Lives ONLY in the backend; executor and scripts receive
# opaque, non-forgeable tokens (x-internal-token header). openssl rand -hex 32
RUN_TOKEN_SECRET=
# Previous secret, valid ONLY for verification during a rotation (optional).
# RUN_TOKEN_SECRET_PREV=

# Service MESH auth (x-service-key header): backendв†’executor and executorв†’broker.
# REQUIRED (the executor is fail-closed). NOT used for /internal/* (в†’ RUN_TOKEN_SECRET).
# Generate with: openssl rand -hex 32
SERVICE_API_KEY=

# JWT вЂ” REQUIRED: min 32 random characters (the app won't start without it).
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# в”Ђв”Ђ PostgreSQL database в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# DB_HOST=localhost for local dev; in Docker it is overridden to `postgres`.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agentory

# в”Ђв”Ђ Server / CORS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PORT=3000
# development locally; in Docker it is overridden to `production`.
NODE_ENV=development
# Allowed origins (comma-separated). Empty = allow-all (dev only).
FRONTEND_URL=http://localhost:5173

# в”Ђв”Ђ Redis В· Qdrant В· Executor (host: localhost in dev, service-name in Docker) в”Ђ
# In Docker these are overridden by the compose environment: block
# (redis://redis:6379, http://qdrant:6333, http://skill-executor:4000).
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
SKILL_EXECUTOR_URL=http://localhost:4000

# в”Ђв”Ђ Upload & Skills (path: local in dev, /app/... in Docker via compose) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Max upload size in MB for /api/files/upload. Drives BOTH the nginx proxy cap
# (client_max_body_size, frontend container) and the backend Multer limit.
# Changing it requires restarting the backend and frontend containers.
MAX_UPLOAD_MB=50
UPLOAD_DIR=./uploads
SKILLS_BASE_PATH=./uploads/skills
# Optional вЂ” output of the files generated by skills (default: UPLOAD_DIR/skills-output)
SKILLS_OUTPUT_DIR=./uploads/skills-output

# Executor tuning (skill execution limits) вЂ” used in Docker by the executor
SKILL_MAX_TIMEOUT_MS=30000
SKILL_MAX_OUTPUT_BYTES=524288
SKILL_MAX_CONCURRENT=5
SKILL_JS_MEMORY_MB=128
SKILL_INSTALL_TIMEOUT_MS=300000

# run_in_sandbox tool fallback WITHOUT the broker (LEVEL 1): 1 = run the code
# IN-PROCESS in the executor (NOT isolated в†’ dev/trusted only). Default 0 = fail-closed.
# With the broker overlay (L2/L3) jobs are isolated regardless; keep this 0.
SANDBOX_ALLOW_INPROCESS=0

# Sandbox session workspaces (per-chat): GC, disk quota, execution timeout.
SANDBOX_SESSION_TTL_MS=86400000        # inactive-session TTL (24h) в†’ reclaimed by the GC
SANDBOX_GC_INTERVAL_MS=3600000         # GC sweep interval (1h)
SANDBOX_SESSION_MAX_BYTES=524288000    # per-session disk quota (500MB); 0 = disabled
SANDBOX_TIMEOUT_MS=120000              # max sandbox execution (120s; installs exceed the 30s skill default)

# Executor bind address INSIDE the container. KEEP 0.0.0.0 in Docker (127.0.0.1 would
# make it unreachable by the backend). Only relevant for the containerized executor.
EXECUTOR_HOST=0.0.0.0

# в”Ђв”Ђ Skill registry (GitHub marketplace) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SKILLS_REGISTRY_URL=https://raw.githubusercontent.com/agentoryhq/agentory-skills/main/registry.json
SKILLS_REGISTRY_CACHE_TTL_MS=300000
# SKILLS_REGISTRY_ALLOWED_DOMAINS=my-cdn.example.com
# SKILLS_REGISTRY_STRICT_CHECKSUM=false   # true = reject downloads without a checksum

# в”Ђв”Ђ Agent (LangGraph) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Step limit per message (1 LLMв†”tool round = 2 steps). Default 50 в‰€ 25 LLM calls.
AGENT_RECURSION_LIMIT=50
# Character cap for tool output re-injected into the history (replay). Default 3000.
REPLAY_TOOL_OUTPUT_MAX_CHARS=3000

# в”Ђв”Ђ LLM В· Embedding В· Vector DB (provider) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# These are ALL configured from the admin UI в†’ Settings в†’ AI System, encrypted in the DB.
# No keys/providers here.

# в”Ђв”Ђ Internal AI microservices (Docker containers ONLY) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# These do NOT have their own .env: docker-compose uses them as build-args +
# environment of the `embedding` and `whisper` containers. They configure the model
# that the microservice loads/serves, not a backend fallback (providers are chosen
# from the UI). In non-Docker dev they start with their own start.sh, which reads
# these vars.

# embedding-service (port 8000)
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
EMBEDDING_DEVICE=cpu          # cpu | cuda  (cuda needs an NVIDIA GPU; also a build-arg)
EMBEDDING_BATCH_SIZE=32

# whisper-service вЂ” faster-whisper voice transcription (port 9000)
WHISPER_MODEL=small           # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu            # cpu | cuda
WHISPER_COMPUTE_TYPE=int8     # int8 | int8_float16 | float16 | float32

# в”Ђв”Ђ Auto-Scheduling вЂ” per-user guardrail on automations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SCHED_MAX_TASKS_PER_USER=25      # total automations (pending+active) per user
SCHED_MAX_ACTIVE_RECURRING=10    # active recurring (cron) automations per user
SCHED_MAX_TOKENS_PER_RUN=200000  # token cap per run: beyond it, the automation is disabled (0 = off)

# в”Ђв”Ђ Branding в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
APP_NAME=Agentory

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# OVERLAY C1 вЂ” egress allowlist (opt-in)
#   docker compose -f docker-compose.yml -f docker-compose.egress.yml up -d
# The allowed domains are declared in egress-proxy/squid.conf (not here).
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# OVERLAY D2 вЂ” container-per-job via broker (opt-in)
#   docker compose -f docker-compose.yml -f docker-compose.broker.yml up -d
# Requires a shared HOST path (bind-mount) across backend/executor/broker.
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

# ABSOLUTE host path of the shared data folder (skills/work/state/output).
# MUST be absolute. Example: /opt/agentory/data вЂ” or leave EMPTY and install.sh fills an
# OS-appropriate absolute default ($HOME/agentory-data on macOS, /srv/agentory/data on Linux).
HOST_DATA_DIR=

# Job runtime: runc (default) | runsc (gVisor; requires runsc + BROKER_ALLOW_RUNSC=1)
JOB_RUNTIME=runc
BROKER_ALLOW_RUNSC=0

# Operator opt-in for the sandbox 'trusted' execution profile (writable rootfs + root +
# default caps, so the code can apt-get system libraries at runtime). The admin still has to
# select 'trusted' in Settings в†’ Sandbox; without this flag the broker forces 'hardened'.
# Enable ONLY on a trusted single-tenant deploy or under gVisor (BROKER_ALLOW_RUNSC=1).
BROKER_ALLOW_PRIVILEGED_SANDBOX=0

# Per-job limits (broker)
JOB_MEMORY=256m
JOB_PIDS=128
JOB_TIMEOUT_MS=120000

# Nix store shared into jobs with system.nix deps (mounted /nix:ro). The broker overlay
# defaults BROKER_NIX_VOLUME to the executor's own `agentory_nix_store` named volume, so
# system.nix skills work out of the box вЂ” no need to set anything here. Override only for a
# real HOST Nix install: set BROKER_NIX_STORE to an absolute host path (takes over from the
# volume when BROKER_NIX_VOLUME is cleared).
# BROKER_NIX_VOLUME=agentory_nix_store
BROKER_NIX_STORE=

# Docker networks allowed per-job beyond 'none' (comma-separated). The broker rejects
# any network not listed. Needed to enable the sandbox egress/internet:
#   - sandbox with 'egress' network (allowlist proxy): add the egress network (e.g. sandboxnet)
#   - sandbox with 'open' network (full internet): add the open network (e.g. bridge)
# Example: BROKER_ALLOWED_NETWORKS=bridge   (or "sandboxnet,bridge")
BROKER_ALLOWED_NETWORKS=

# Docker network used by the sandboxNetwork='open' mode (full internet).
# Default 'bridge'. Must also be present in BROKER_ALLOWED_NETWORKS.
SANDBOX_OPEN_NETWORK=bridge

# в”Ђв”Ђ Skill network access (Phase 1/2/3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Baseline internal network for skill jobs (Phase 1): every job reaches
# backend:3000/internal/* with NO route to the WAN. Matches the fixed `name:` of the
# network in docker-compose.broker.yml вЂ” change only if you renamed it there.
JOB_INTERNAL_NETWORK=agentory-internal

# Egress network (Phase 2, LEVEL 3): jobs that declared external domains
# (runtime.network in SKILL.md) are also attached here (external via the squid
# allowlist). Set to the egress overlay network name (sandboxnet). Empty = no egress.
JOB_EGRESS_NETWORK=

# "Global" reserved networks (Phase 3): docker networks attached to EVERY skill job
# (always-on, e.g. an operator LAN all skills may use). Comma-separated; each must ALSO
# be in BROKER_ALLOWED_NETWORKS. Default empty (per-skill grants only).
BROKER_GLOBAL_NETWORKS=

# "Grantable" reserved-network CATALOG (Phase 3): networks an admin can grant per-skill
# from the UI (Settings в†’ Skills в†’ skill в†’ Reserved networks). JSON array of
# {id,dockerNetwork,label,description,kind}; each dockerNetwork must ALSO be in
# BROKER_ALLOWED_NETWORKS. `kind` is 'lan' (corporate LAN/VPN preset в†’ LAN badge in the UI)
# or 'custom' (default). Default empty.
# Example: SKILL_NETWORK_CATALOG=[{"id":"lan-nas","dockerNetwork":"lan-nas","label":"Office NAS","description":"SMB 192.168.1.0/24","kind":"lan"}]
SKILL_NETWORK_CATALOG=
